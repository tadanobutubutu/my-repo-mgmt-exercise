{
  "name": "Python 3",
  "image": "mcr.microsoft.com/devcontainers/python:3.14",
  "forwardPorts": [8000],
  "postCreateCommand": "bash ./.devcontainer/postCreate.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "ms-python.python",
        "ms-python.debugpy",
        "mongodb.mongodb-vscode"
      ]
    }
  }
}
